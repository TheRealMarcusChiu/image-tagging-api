OPENAI_API_KEY=
# Direct Anthropic Console API key authentication.
ANTHROPIC_API_KEY=
# Optional Anthropic bearer-token authentication. CLAUDE_CODE_OAUTH_TOKEN is a
# best-effort path for tokens generated by `claude setup-token` with Claude Max/Pro.
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional defaults
DEFAULT_PROVIDER=openai
DEFAULT_OPENAI_MODEL=gpt-4.1-mini
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-6
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
DEFAULT_OLLAMA_MODEL=llava:latest
REQUEST_TIMEOUT_SECONDS=60
VALIDATE_PROVIDER_CREDENTIALS_ON_STARTUP=true
STARTUP_CHECK_TIMEOUT_SECONDS=10
ANTHROPIC_STARTUP_CHECK_MODEL=claude-sonnet-4-6

# Audio/video tagging: external stt-tts transcription service.
STT_TTS_BASE_URL=https://stt-tts.lan
# Transcription model the stt-tts server should use.
STT_MODEL=large-v3-turbo
# Optional language hint passed to transcription (auto-detect if unset).
STT_LANGUAGE=
# Leave unset to use the stt-tts server's VAD default. Uncomment and set false if
# transcripts come back empty (VAD dropped the audio).
# STT_VAD_FILTER=false
STT_REQUEST_TIMEOUT_SECONDS=300
# TLS for STT_TTS_BASE_URL. Verification is OFF by default since stt-tts usually
# runs with a self-signed .lan cert. Set STT_TTS_VERIFY_SSL=true to enforce it,
# optionally pointing STT_TTS_CA_CERT at the CA bundle (a CA path verifies).
STT_TTS_VERIFY_SSL=false
STT_TTS_CA_CERT=
