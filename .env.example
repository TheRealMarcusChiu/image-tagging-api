OPENAI_API_KEY=
# Direct Anthropic Console API key authentication.
ANTHROPIC_API_KEY=
# Optional Anthropic bearer-token authentication. CLAUDE_CODE_OAUTH_TOKEN is a
# best-effort path for tokens generated by `claude setup-token` with Claude Max/Pro.
ANTHROPIC_AUTH_TOKEN=
CLAUDE_CODE_OAUTH_TOKEN=
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Optional defaults
DEFAULT_PROVIDER=openai
DEFAULT_OPENAI_MODEL=gpt-4.1-mini
DEFAULT_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
DEFAULT_GEMINI_MODEL=gemini-2.0-flash
DEFAULT_OLLAMA_MODEL=llava:latest
REQUEST_TIMEOUT_SECONDS=60
VALIDATE_PROVIDER_CREDENTIALS_ON_STARTUP=true
STARTUP_CHECK_TIMEOUT_SECONDS=10
